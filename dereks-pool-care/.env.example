# Email Service (Resend)
# Sign up at https://resend.com to get your API key
RESEND_API_KEY=re_your_api_key_here
BUSINESS_EMAIL=info@derekscompletepoolcare.com

# Google Maps API
# Get your API key from https://console.cloud.google.com/google/maps-apis
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Rate Limiting (Upstash Redis) - Optional
# Sign up at https://upstash.com for free Redis instance
# If not provided, will use in-memory rate limiting
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://derekscompletepoolcare.com

# Google Search Console Verification
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your_verification_code_here
